   MetaKmsDevice *kms_device = meta_kms_crtc_get_device (kms_crtc);
@@ -1287,7 +1340,8 @@ realize_cursor_sprite_for_crtc (MetaCursorRenderer *renderer,
       return realize_cursor_sprite_from_xcursor_for_crtc (renderer,
                                                           crtc_kms,
                                                           target_color_state,
-                                                          sprite_xcursor);
+                                                          sprite_xcursor,
+                                                          single_crtc);
     }
 #ifdef HAVE_WAYLAND
   else if (META_IS_CURSOR_SPRITE_WAYLAND (cursor_sprite))
@@ -1298,7 +1352,8 @@ realize_cursor_sprite_for_crtc (MetaCursorRenderer *renderer,
       return realize_cursor_sprite_from_wl_buffer_for_crtc (renderer,
                                                             crtc_kms,
                                                             target_color_state,
-                                                            sprite_wayland);
+                                                            sprite_wayland,
+                                                            single_crtc);
     }
 #endif
   else

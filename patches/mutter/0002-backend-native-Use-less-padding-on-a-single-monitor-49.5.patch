+static MtkRectangle
+calculate_cursor_shift_and_extend(int      *crtc_dst_width,
+                                  int      *crtc_dst_height,
+                                  int      *hot_x,
+                                  int      *hot_y,
+                                  const int padding,
+                                  gboolean  single_crtc)
+{
+  MtkRectangle cursor_area = MTK_RECTANGLE_INIT (0, 0, *crtc_dst_width, *crtc_dst_height);
+
+  /*
+  If limited to a single crtc, the cursors hot spot can not leave the crtc. Due to this
+  fact padding can be applied around the hotspot only while still ensuring, that the
+  intersection with the screen is at least as large as the padding. This reduces the size
+  of the overlay.
+
+  In a multi crtc setup (e.g. multiple screens) a cursors hotspot can leave one screen
+  until the cursor has fully left the screen. To handle this case, the cursor must be
+  padded uniformly with full padding.
+  */
+  if (single_crtc)
+    {
+      /* only add padding around the hotspot */
+      if (*hot_x < padding)
+        {
+          int shift = padding - *hot_x;
+          *hot_x += shift;
+          cursor_area.x += shift;
+          *crtc_dst_width += shift;
+        }
+
+      if (*hot_y < padding)
+        {
+          int shift = padding - *hot_y;
+          *hot_y += shift;
+          cursor_area.y += shift;
+          *crtc_dst_height += shift;
+        }
+
+      *crtc_dst_width = *hot_x + MAX (*crtc_dst_width - *hot_x, padding);
+      *crtc_dst_height = *hot_y + MAX (*crtc_dst_height - *hot_y, padding);
+    }
+  else
+    {
+      /* extend the cursors surface uniformly to include padding */
+      cursor_area.x += padding;
+      cursor_area.y += padding;
+      *crtc_dst_width += 2 * padding;
+      *crtc_dst_height += 2 * padding;
+
+      /* and shift the hotspot */
+      *hot_x += padding;
+      *hot_y += padding;
+    }
+
+  return cursor_area;
+}

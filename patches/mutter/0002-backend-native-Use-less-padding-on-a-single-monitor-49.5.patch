     meta_cursor_renderer_native_get_instance_private (native);
@@ -997,33 +1058,23 @@ load_scaled_and_transformed_cursor_sprite (MetaCursorRendererNative *native,
       gbm_format != cursor_renderer_gpu_data->drm_format ||
       !clutter_color_state_equals (cursor_color_state, target_color_state))
     {
-      int crtc_cursor_x, crtc_cursor_y;

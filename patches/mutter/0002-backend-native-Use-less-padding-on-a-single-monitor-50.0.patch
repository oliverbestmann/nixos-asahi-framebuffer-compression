@@ -1339,7 +1390,8 @@ realize_cursor_sprite_for_crtc (MetaCursorRenderer *renderer,
       return realize_cursor_sprite_from_wl_buffer_for_crtc (renderer,
                                                             crtc_kms,
                                                             target_color_state,
-                                                            cursor_wayland);
+                                                            cursor_wayland,
+                                                            single_crtc);
     }
   else
